rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Exige o login (anônimo) do Firebase em todas as coleções do app
    // (processos, acompanhamentos, audiencias, doe, prazos, config,
    //  pushSubscriptions, notificacoes...). Fecha o acesso de quem não está no app.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
